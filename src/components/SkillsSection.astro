const catColors: Record<string, { wrapper: string; label: string; dot: string }> = {
  Frontend: { wrapper: "bg-cyan-50 border-cyan-200 hover:border-cyan-400 hover:shadow-cyan-100", label: "text-cyan-700 bg-cyan-100", dot: "bg-cyan-400" },
  Backend:  { wrapper: "bg-sky-50 border-sky-200 hover:border-sky-400 hover:shadow-sky-100",   label: "text-sky-700 bg-sky-100",   dot: "bg-sky-400"  },
  Database: { wrapper: "bg-blue-50 border-blue-200 hover:border-blue-400 hover:shadow-blue-100", label: "text-blue-700 bg-blue-100", dot: "bg-blue-400" },
  DevOps:   { wrapper: "bg-indigo-50 border-indigo-200 hover:border-indigo-400 hover:shadow-indigo-100", label: "text-indigo-700 bg-indigo-100", dot: "bg-indigo-400" },
  Security: { wrapper: "bg-red-50 border-red-200 hover:border-red-400 hover:shadow-red-100",   label: "text-red-700 bg-red-100",   dot: "bg-red-400"  },
  Data:     { wrapper: "bg-amber-50 border-amber-200 hover:border-amber-400 hover:shadow-amber-100", label: "text-amber-700 bg-amber-100", dot: "bg-amber-400" },
};

const categories = Object.keys(catColors);
---

<section
  id="skills"
  class="py-24 px-6"
  style="background: linear-gradient(145deg,#faf5ff 0%,#ede9fe 25%,#f0f9ff 60%,#e0f2fe 100%);"
  aria-labelledby="skills-heading"
>
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-12">
      <p class="text-xs font-semibold tracking-widest text-slate-400 uppercase mb-2">What I use</p>
      <h2 id="skills-heading" class="text-4xl font-extrabold text-slate-900 mb-3">Skills &amp; Technologies</h2>
      <p class="text-slate-500 text-sm max-w-xl mx-auto">
        Stack teknologi yang saya gunakan untuk membangun aplikasi production-grade —
        dari frontend hingga infrastructure, security, dan machine learning.
      </p>
    </div>

    <!-- Category filter tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" role="list" aria-label="Kategori skill">
      {categories.map(cat => (
        <span
          role="listitem"
          class={`flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full border ${catColors[cat].label} border-current`}
        >
          <span class={`w-2 h-2 rounded-full ${catColors[cat].dot}`}></span>
          {cat}
        </span>
      ))}
    </div>

    <!-- Skills grid -->
    <ul class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-7 gap-3 list-none p-0 m-0">
      {SKILLS.map(skill => (
        <li>
          <div
            class={`rounded-2xl border p-3 flex flex-col items-center justify-center gap-2 cursor-default transition-all duration-200 hover:-translate-y-2 hover:shadow-lg ${catColors[skill.cat].wrapper}`}
            title={`${skill.name} — ${skill.cat}`}
          >
            <div set:html={skill.svg} />
            <p class="text-xs font-semibold text-slate-600 text-center leading-tight">{skill.name}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>
