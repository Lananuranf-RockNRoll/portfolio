---
// src/components/BlogTeaser.astro

interface Post {
  slug: string;
  title: string;
  desc: string;
  date: string;
  readTime: string;
  tags: string[];
  accent: string;
  border: string;
  published: boolean;
}

const POSTS: Post[] = [
  {
    slug: "/blog/cara-deploy-react-go-docker-aws/",
    title: "Cara Deploy Fullstack App React + Go Fiber ke AWS EC2 dengan Docker & GitHub Actions",
    desc: "Panduan lengkap dari nol: setup EC2, Docker Compose, Nginx reverse proxy, SSL, sampai CI/CD pipeline otomatis yang jalan tiap push ke main.",
    date: "28 April 2026",
    readTime: "12 min read",
    tags: ["Docker","AWS EC2","Go Fiber","GitHub Actions","CI/CD"],
    accent: "from-sky-500 to-blue-600",
    border: "border-sky-200",
    published: true,
  },
  {
    slug: "/blog/devsecops-pipeline-github-actions/",
    title: "Membangun DevSecOps Pipeline di GitHub Actions: GitLeaks, Semgrep, Trivy, OWASP ZAP",
    desc: "Shift security left dari hari pertama. Panduan step-by-step mengintegrasikan 4 tools keamanan ke GitHub Actions pipeline.",
    date: "Coming soon",
    readTime: "15 min read",
    tags: ["DevSecOps","GitLeaks","Semgrep","Trivy","OWASP ZAP"],
    accent: "from-violet-500 to-purple-600",
    border: "border-violet-200",
    published: false,
  },
  {
    slug: "/blog/go-fiber-vs-nodejs-performa/",
    title: "Go Fiber vs Node.js Express: Benchmark Performa untuk Backend REST API",
    desc: "Benchmark langsung antara Go Fiber dan Node.js Express — latency, throughput, memory usage, dan kapan harus pilih masing-masing.",
    date: "Coming soon",
    readTime: "8 min read",
    tags: ["Go Fiber","Node.js","Backend","Performance","Benchmark"],
    accent: "from-emerald-500 to-teal-600",
    border: "border-emerald-200",
    published: false,
  },
];
---

<section
  id="blog"
  class="px-6 py-24"
  style="background: linear-gradient(155deg,#f0fdf4 0%,#dcfce7 20%,#f8fafc 50%,#fef3c7 80%,#fff7ed 100%);"
  aria-labelledby="blog-heading"
>
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-12">
      <p class="text-xs font-semibold tracking-widest text-slate-400 uppercase mb-2">Artikel teknis</p>
      <h2 id="blog-heading" class="text-4xl font-extrabold text-slate-900">Blog</h2>
      <p class="text-slate-500 mt-2 text-sm max-w-xl mx-auto">
        Saya berbagi pengalaman nyata, studi kasus, dan tutorial dari proyek yang pernah dibangun.
        Bukan teori — semua based on real implementation.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {POSTS.map(post => (
        <article class={`flex flex-col bg-white rounded-3xl border ${post.border} shadow-sm overflow-hidden hover:-translate-y-2 hover:shadow-lg transition-all duration-200`}>
          <div class={`h-1.5 bg-gradient-to-r ${post.accent}`}></div>
          <div class="p-6 flex flex-col gap-3 flex-1">
            <div class="flex items-center justify-between">
              <span class="text-xs text-slate-400 font-medium">{post.date}</span>
              <span class="text-xs text-slate-400">{post.readTime}</span>
            </div>

            <h3 class="font-bold text-slate-900 text-base leading-snug">
              {post.published
                ? <a href={post.slug} class="hover:text-sky-600 transition-colors">{post.title}</a>
                : <span class="text-slate-500">{post.title}</span>
              }
            </h3>

            <p class="text-slate-500 text-xs leading-relaxed flex-1">{post.desc}</p>

            <div class="flex flex-wrap gap-1.5 mt-1">
              {post.tags.map(t => (
                <span class="text-xs font-medium px-2 py-0.5 bg-slate-50 border border-slate-200 rounded-full text-slate-500">{t}</span>
              ))}
            </div>

            {post.published
              ? <a href={post.slug} class={`mt-2 inline-flex items-center gap-1 text-sm font-semibold text-transparent bg-clip-text bg-gradient-to-r ${post.accent}`}>
                  Baca artikel →
                </a>
              : <span class="mt-2 text-xs font-semibold text-slate-300 uppercase tracking-wide">Coming soon…</span>
            }
          </div>
        </article>
      ))}
    </div>

    <div class="text-center">
      <a href="/blog/" class="inline-flex items-center gap-2 px-6 py-3 border border-slate-200 bg-white rounded-xl font-semibold text-slate-700 hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-colors text-sm shadow-sm">
        Lihat semua artikel →
      </a>
    </div>

  </div>
</section>
