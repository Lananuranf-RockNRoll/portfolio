---
// src/pages/projects/letta-school.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import Footer from '../../components/Footer.astro';

const projectSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Web Management Letta School",
  "description": "Sistem manajemen sekolah fullstack dengan JWT auth, RBAC, dan DevSecOps pipeline lengkap. React + Go Fiber + PostgreSQL + Docker + AWS EC2.",
  "url": "https://school.lananuranf.my.id/",
  "applicationCategory": "WebApplication",
  "programmingLanguage": ["React","TypeScript","Go Fiber","PostgreSQL","Docker"],
  "author": { "@type": "Person", "name": "Maulana Nur Anfajm", "alternateName": "Lananuranf", "url": "https://portfolio.lananuranf.my.id/" }
});
---

<BaseLayout
  title="Letta School — Fullstack School Management System | Maulana Nur Anfajm (Lananuranf)"
  description="Studi kasus: sistem manajemen sekolah fullstack dengan React, Go Fiber, PostgreSQL, Docker, AWS EC2, dan DevSecOps pipeline lengkap (GitLeaks, Semgrep, Trivy, OWASP ZAP). Dibangun oleh Maulana Nur Anfajm (Lananuranf)."
  canonicalURL="https://portfolio.lananuranf.my.id/projects/letta-school/"
  extraSchema={projectSchema}
>
  <MainLayout />

  <main class="pt-14 min-h-screen bg-slate-50">
    <article class="max-w-4xl mx-auto px-6 py-14">

      <!-- Back -->
      <a href="/#projects" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-800 transition-colors mb-8">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        Kembali ke Projects
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-cyan-50 text-cyan-700 border border-cyan-200">Fullstack</span>
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-violet-50 text-violet-700 border border-violet-200">DevSecOps</span>
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-sky-50 text-sky-700 border border-sky-200">AWS EC2</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight mb-3">
          Web Management Letta School
        </h1>
        <p class="text-slate-500 text-base leading-relaxed">
          Sistem manajemen sekolah fullstack production-grade dengan JWT authentication,
          role-based access control, dan DevSecOps pipeline 6 tahap yang berjalan otomatis
          di setiap commit.
        </p>
        <div class="flex gap-3 mt-5">
          <a href="https://school.lananuranf.my.id/" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold rounded-xl text-sm hover:opacity-90 transition-opacity shadow-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            Live Demo
          </a>
          <a href="https://github.com/Lananuranf-RockNRoll/letta-school" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-5 py-2.5 border border-slate-200 bg-white text-slate-700 font-semibold rounded-xl text-sm hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-colors">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            Source Code
          </a>
        </div>
      </header>

      <!-- Tech stack -->
      <div class="flex flex-wrap gap-2 mb-10 p-4 bg-white rounded-2xl border border-slate-200">
        <span class="text-xs font-semibold text-slate-500 w-full mb-1">Tech Stack:</span>
        {["React","TypeScript","Tailwind CSS","Go Fiber","GORM","PostgreSQL","JWT","RBAC","Docker","Docker Compose","AWS EC2","GitHub Actions","Nginx","GitLeaks","Semgrep","Trivy","OWASP ZAP","AWS CloudTrail"].map(t => (
          <span class="text-xs font-medium px-2.5 py-1 bg-slate-50 border border-slate-200 rounded-full text-slate-600">{t}</span>
        ))}
      </div>

      <!-- Case Study -->
      <div class="flex flex-col gap-8">

        <section>
          <h2 class="text-xl font-bold text-slate-900 mb-3 flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-rose-100 flex items-center justify-center text-sm">🔴</span>
            Problem
          </h2>
          <div class="bg-rose-50 border border-rose-200 rounded-2xl p-5 text-slate-600 text-sm leading-relaxed">
            <p>Sekolah Letta membutuhkan platform digital terpadu untuk mengelola data siswa, guru, absensi, jadwal, dan laporan akademik — sebelumnya semua dikelola manual menggunakan spreadsheet yang rawan error, tidak aman, dan sulit diakses oleh multiple user secara bersamaan.</p>
            <p class="mt-2">Selain itu, sistem perlu mendukung tiga level pengguna dengan hak akses berbeda: admin (akses penuh), guru (kelola kelas dan nilai), dan siswa (view-only data pribadi).</p>
          </div>
        </section>

        <section>
          <h2 class="text-xl font-bold text-slate-900 mb-3 flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-emerald-100 flex items-center justify-center text-sm">🟢</span>
            Solution
          </h2>
          <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-5 text-slate-600 text-sm leading-relaxed">
            <p>Membangun school management system berbasis web fullstack dengan arsitektur yang jelas: React + TypeScript di frontend untuk UI yang responsif dan type-safe, Go Fiber di backend karena performanya yang superior (mampu handle jutaan request/detik dengan memory footprint minimal), dan PostgreSQL sebagai database relasional.</p>
            <p class="mt-2">Sistem RBAC diimplementasikan di layer middleware Go Fiber — setiap API endpoint memvalidasi JWT token dan memeriksa role pengguna sebelum memberikan akses. Tiga role: <strong>admin</strong> (full CRUD), <strong>guru</strong> (manage kelas, absensi, nilai), <strong>siswa</strong> (view data pribadi dan jadwal).</p>
          </div>
        </section>

        <section>
          <h2 class="text-xl font-bold text-slate-900 mb-3 flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-violet-100 flex items-center justify-center text-sm">🔵</span>
            DevSecOps Pipeline
          </h2>
          <div class="bg-violet-50 border border-violet-200 rounded-2xl p-5 text-slate-600 text-sm leading-relaxed">
            <p class="mb-3">Setiap push ke branch <code class="bg-white px-1.5 py-0.5 rounded border border-violet-200">main</code> otomatis menjalankan pipeline GitHub Actions dengan 6 tahap security:</p>
            <ol class="flex flex-col gap-2 list-none p-0">
              {[
                { step:"1", tool:"GitLeaks", desc:"Secret scanning — deteksi API key, password, atau token yang tidak sengaja ter-commit ke repository." },
                { step:"2", tool:"Semgrep", desc:"SAST (Static Application Security Testing) — analisis source code Go dan JavaScript untuk mendeteksi kerentanan keamanan." },
                { step:"3", tool:"Dependency Audit", desc:"npm audit + go mod tidy — memastikan tidak ada dependency dengan CVE yang diketahui." },
                { step:"4", tool:"Trivy", desc:"Container image scanning — scan Docker image sebelum push ke registry, deteksi vulnerability di OS packages." },
                { step:"5", tool:"OWASP ZAP", desc:"DAST (Dynamic Application Security Testing) — mensimulasikan serangan nyata (SQL injection, XSS, CSRF) ke staging environment." },
                { step:"6", tool:"AWS CloudTrail", desc:"Audit log semua aktivitas di infrastruktur AWS untuk forensik dan compliance monitoring." },
              ].map(s => (
                <li class="flex items-start gap-3 bg-white rounded-xl p-3 border border-violet-100">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full bg-violet-500 text-white text-xs font-bold flex items-center justify-center">{s.step}</span>
                  <div>
                    <span class="font-semibold text-slate-800">{s.tool}</span>
                    <span class="text-slate-500"> — {s.desc}</span>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </section>

        <section>
          <h2 class="text-xl font-bold text-slate-900 mb-3 flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-amber-100 flex items-center justify-center text-sm">⚡</span>
            Infrastructure
          </h2>
          <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 text-slate-600 text-sm leading-relaxed">
            <p>Aplikasi di-deploy di AWS EC2 (Ubuntu 22.04 LTS) menggunakan Docker Compose untuk orchestration. Nginx berfungsi sebagai reverse proxy yang menangani SSL termination, HTTP-to-HTTPS redirect, static file serving, dan routing request ke container yang tepat.</p>
            <p class="mt-2">GitHub Actions CI/CD pipeline otomatis: setiap merge ke main → security scan → SSH ke EC2 → git pull → docker compose up --build -d → aplikasi live dalam 2-3 menit tanpa manual intervention.</p>
          </div>
        </section>

      </div>

      <!-- CTA -->
      <div class="mt-12 p-6 bg-gradient-to-r from-cyan-50 to-blue-50 border border-cyan-200 rounded-3xl text-center">
        <p class="font-bold text-slate-900 mb-1">Tertarik dengan project ini?</p>
        <p class="text-sm text-slate-500 mb-4">Gua open to discuss soal tech stack, architecture, atau opportunities.</p>
        <div class="flex justify-center gap-3 flex-wrap">
          <a href="mailto:lananuranf@gmail.com" class="px-5 py-2.5 bg-sky-500 text-white font-semibold rounded-xl text-sm hover:bg-sky-600 transition-colors">Hubungi Gua</a>
          <a href="/" class="px-5 py-2.5 border border-slate-200 bg-white text-slate-700 font-semibold rounded-xl text-sm hover:bg-slate-50 transition-colors">Lihat Portfolio</a>
        </div>
      </div>

    </article>
  </main>

  <Footer />
</BaseLayout>
