---
// src/layouts/MainLayout.astro — Navbar statis, zero JS framework
---

<nav
  id="navbar"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
  aria-label="Navigasi utama"
>
  <div class="max-w-7xl mx-auto h-14 px-6 md:px-12 flex items-center justify-between">

    <a href="/" class="text-xl md:text-2xl font-bold tracking-tight text-slate-900 hover:opacity-80 transition-opacity">
      Lananuranf
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium" role="menubar">
      {[
        { label: "Home",     href: "/#home"     },
        { label: "About",    href: "/#about"    },
        { label: "Skills",   href: "/#skills"   },
        { label: "Projects", href: "/#projects" },
        { label: "Blog",     href: "/blog/"     },
        { label: "Contact",  href: "/#contact"  },
      ].map(link => (
        <a href={link.href} role="menuitem"
          class="relative text-slate-600 hover:text-slate-900 transition-colors group">
          {link.label}
          <span class="absolute -bottom-0.5 left-0 w-0 h-0.5 bg-slate-900 rounded-full group-hover:w-full transition-all duration-300"></span>
        </a>
      ))}
    </div>

    <!-- Hamburger -->
    <button type="button" id="menu-btn" aria-label="Buka menu" aria-expanded="false" aria-controls="mobile-menu"
      class="md:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-lg hover:bg-slate-100 transition-colors">
      <span id="bar1" class="block w-5 h-0.5 bg-slate-800 transition-all duration-300 origin-center"></span>
      <span id="bar2" class="block w-5 h-0.5 bg-slate-800 transition-all duration-300"></span>
      <span id="bar3" class="block w-5 h-0.5 bg-slate-800 transition-all duration-300 origin-center"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white/95 backdrop-blur-md border-t border-slate-100" role="menu">
    <div class="flex flex-col px-6 py-3">
      {[
        { label: "Home",     href: "/#home"     },
        { label: "About",    href: "/#about"    },
        { label: "Skills",   href: "/#skills"   },
        { label: "Projects", href: "/#projects" },
        { label: "Blog",     href: "/blog/"     },
        { label: "Contact",  href: "/#contact"  },
      ].map(link => (
        <a href={link.href} role="menuitem"
          class="mobile-link py-4 text-slate-600 hover:text-slate-900 font-medium border-b border-slate-100 last:border-0 transition-colors">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar  = document.getElementById('navbar')!;
  const btn     = document.getElementById('menu-btn')!;
  const menu    = document.getElementById('mobile-menu')!;
  const bar1    = document.getElementById('bar1')!;
  const bar2    = document.getElementById('bar2')!;
  const bar3    = document.getElementById('bar3')!;
  let isOpen    = false;

  // Scroll effect
  const updateNav = () => {
    if (window.scrollY > 20) {
      navbar.classList.add('backdrop-blur-md','bg-white/90','shadow-sm','border-b','border-slate-100');
    } else {
      navbar.classList.remove('backdrop-blur-md','bg-white/90','shadow-sm','border-b','border-slate-100');
    }
  };
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Mobile toggle
  btn.addEventListener('click', () => {
    isOpen = !isOpen;
    btn.setAttribute('aria-expanded', String(isOpen));
    menu.classList.toggle('hidden', !isOpen);
    bar1.classList.toggle('translate-y-2',  isOpen);
    bar1.classList.toggle('rotate-45',      isOpen);
    bar2.classList.toggle('opacity-0',      isOpen);
    bar3.classList.toggle('-translate-y-2', isOpen);
    bar3.classList.toggle('-rotate-45',     isOpen);
  });

  // Close on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      isOpen = false;
      btn.setAttribute('aria-expanded', 'false');
      menu.classList.add('hidden');
      bar1.classList.remove('translate-y-2','rotate-45');
      bar2.classList.remove('opacity-0');
      bar3.classList.remove('-translate-y-2','-rotate-45');
    });
  });
</script>
